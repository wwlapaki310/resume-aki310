<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{basics.name}} – {{meta.title}}</title>
    <style>
        /* ── Density ────────────────────────────────── */
        :root { --col-gap:30px;--sec-mb:18px;--li-size:11pt;--li-lh:1.4;--li-mb:3px;--h1-size:40px; }
        [data-density="compact"] { --col-gap:20px;--sec-mb:12px;--li-size:10pt;--li-mb:2px;--h1-size:34px; }
        [data-density="tight"]   { --col-gap:14px;--sec-mb:8px; --li-size:9.5pt;--li-mb:1px;--h1-size:30px; }

        /* ── Lang toggle ─────────────────────────────── */
        .lang-toggle { position:fixed;top:12px;right:16px;display:flex;gap:4px;z-index:100;background:white;padding:4px;border-radius:6px;box-shadow:0 2px 8px rgba(0,0,0,.15); }
        .lang-toggle button { padding:3px 10px;border:1.5px solid #2c3e50;border-radius:4px;font-size:11px;font-weight:700;cursor:pointer;background:white;color:#2c3e50;transition:all .15s; }
        .lang-toggle button.active { background:#2c3e50;color:white; }
        body[data-lang="en"] .ja, body[data-lang="ja"] .en { display:none; }
        @media print { .lang-toggle { display:none; } }

        /* ── Base ───────────────────────────────────── */
        * { margin:0;padding:0;box-sizing:border-box; }
        body { font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;line-height:var(--li-lh);color:#333;background:#f5f5f5; }
        .container { max-width:850px;margin:20px auto;background:white;padding:40px 50px;box-shadow:0 0 10px rgba(0,0,0,.1); }
        header { text-align:center;margin-bottom:25px;padding-bottom:15px;border-bottom:2px solid #2c3e50; }
        h1 { font-size:var(--h1-size);color:#2c3e50;margin-bottom:4px; }
        .subtitle { font-size:13px;color:#555;margin-bottom:8px; }
        .contact { font-size:12px;color:#555;display:flex;justify-content:center;gap:15px;flex-wrap:wrap; }
        .contact a { color:#555;text-decoration:none; }
        .contact svg { vertical-align:middle;margin-right:4px; }
        .content { display:grid;grid-template-columns:2fr 1fr;gap:var(--col-gap); }
        .section { margin-bottom:var(--sec-mb); }
        h2 { font-size:14px;color:#2c3e50;text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;padding-bottom:5px;border-bottom:1.5px solid #3498db; }
        .job-group { font-size:11.5px;font-weight:bold;color:#2c3e50;margin-top:7px;margin-bottom:2px; }
        .job-header { display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px; }
        .job-title { font-size:13.5px;font-weight:bold;color:#2c3e50;text-decoration:underline; }
        .job-location { font-size:10px;color:#7f8c8d;font-style:italic; }
        .job-period { font-size:10px;color:#7f8c8d; }
        ul { margin-left:15px;margin-top:5px; }
        li { font-size:var(--li-size);margin-bottom:var(--li-mb);line-height:var(--li-lh); }
        .skills-grid { display:grid;gap:6px;font-size:var(--li-size); }
        .skill-category { margin-bottom:4px; }
        .skill-category strong { color:#2c3e50; }
        .summary-para { font-size:var(--li-size);line-height:1.5; }
        .right-column { font-size:var(--li-size); }
        .education-item { margin-bottom:12px; }
        .degree { font-weight:bold;color:#2c3e50; }
        .institution { color:#555;font-size:10pt; }
        .date { color:#7f8c8d;font-size:9pt;font-style:italic; }
        .cert-item,.award-item { margin-bottom:8px;line-height:1.3; }
        .back-link { display:inline-block;margin-bottom:16px;font-size:12px;color:#7f8c8d;text-decoration:none;border-bottom:1px solid transparent;transition:all .15s; }
        .back-link:hover { color:#2c3e50;border-color:#2c3e50; }

        /* ── Print ──────────────────────────────────── */
        @page { size:A4;margin:5mm 8mm; }
        @media print {
            body { background:white; }
            .container { max-width:100%;margin:0;padding:0;box-shadow:none; }
            .section,.job-header,.education-item,.cert-item,.award-item { page-break-inside:avoid; }
            .back-link { display:none; }
            header { margin-bottom:7px;padding-bottom:5px; }
            h1 { font-size:calc(var(--h1-size)*0.72); }
            .contact { font-size:10px;gap:10px; }
            h2 { font-size:11pt;margin-bottom:6px;padding-bottom:3px; }
            .section { margin-bottom:7px; }
            .content { gap:16px; }
            li,.summary-para { font-size:calc(var(--li-size)*0.82);line-height:1.24; }
            li { margin-bottom:1px; }
            ul { margin-left:12px;margin-top:2px; }
            .skills-grid { gap:2px;font-size:calc(var(--li-size)*0.82); }
            .skill-category { margin-bottom:2px; }
            .job-title { font-size:10pt; }
            .award-item,.cert-item { margin-bottom:3px;line-height:1.2;font-size:calc(var(--li-size)*0.82); }
            .education-item { margin-bottom:5px; }
            .right-column { font-size:calc(var(--li-size)*0.82); }
            .right-column p { margin-bottom:2px;line-height:1.18;font-size:calc(var(--li-size)*0.77); }
            .job-header { margin-bottom:2px; }
            .job-group { font-size:10pt;margin-top:6px;margin-bottom:1px; }
        }
    </style>
</head>
<body data-lang="en">

<div class="lang-toggle">
    <button id="btn-en" class="active" onclick="setLang('en')">EN</button>
    <button id="btn-ja" onclick="setLang('ja')">JA</button>
</div>

<div class="container" data-density="{{_density}}">
    <a class="back-link" href="../">← <span class="en">All Resumes</span><span class="ja">一覧へ戻る</span></a>
    <header>
        <h1>
            <span class="en">{{basics.name}}</span>
            <span class="ja">{{basics.name_ja}}</span>
        </h1>
        <div class="subtitle">
            <span class="en">{{basics.label}}</span>
            <span class="ja">{{basics.label_ja}}</span>
        </div>
        <div class="contact">
            <span>
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#2c3e50"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                <a href="mailto:{{basics.email}}">{{basics.email}}</a>
            </span>
            <span>
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#2c3e50"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                {{basics.phone}}
            </span>
            <span>
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#2c3e50"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
                <a href="{{basics.linkedin}}" target="_blank">LinkedIn</a>
            </span>
            <span>
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#2c3e50"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                <a href="{{basics.github}}" target="_blank">{{basics.github_handle}}</a>
            </span>
        </div>
    </header>

    <div class="content">
        <div class="left-column">
            {{#ifIn meta.sections_left "summary"}}
            <section class="section">
                <h2><span class="en">{{i18n.en.summary}}</span><span class="ja">{{i18n.ja.summary}}</span></h2>
                {{#if _summaryIsArray}}
                <ul class="en">{{#each _summaryItems}}<li>{{{this}}}</li>{{/each}}</ul>
                <ul class="ja">{{#each _summaryItems_ja}}<li>{{{this}}}</li>{{/each}}</ul>
                {{else}}
                <p class="summary-para en">{{{_summaryText}}}</p>
                <p class="summary-para ja">{{{_summaryText_ja}}}</p>
                {{/if}}
            </section>
            {{/ifIn}}
            {{#ifIn meta.sections_left "skills"}}
            <section class="section">
                <h2><span class="en">{{i18n.en.skills}}</span><span class="ja">{{i18n.ja.skills}}</span></h2>
                <div class="skills-grid">
                    {{#each skills}}
                    <div class="skill-category">
                        <strong class="en">{{name}}:</strong><strong class="ja">{{name_ja}}:</strong>
                        {{keywords_joined}}
                    </div>
                    {{/each}}
                </div>
            </section>
            {{/ifIn}}
            {{#ifIn meta.sections_left "work"}}
            <section class="section">
                <h2><span class="en">{{i18n.en.experience}}</span><span class="ja">{{i18n.ja.experience}}</span></h2>
                {{#each work}}
                <div class="job-header"{{#unless @first}} style="margin-top:10px;"{{/unless}}>
                    <div>
                        <span class="job-title en">{{position}}</span>
                        <span class="job-title ja">{{position_ja}}</span>
                        <span class="job-location"> | {{company}}, {{location}}</span>
                    </div>
                    <span class="job-period">{{startDate_fmt}} – {{endDate_fmt}}</span>
                </div>
                {{#each groups}}
                <p class="job-group en">{{name}}</p>
                <p class="job-group ja">{{name_ja}}</p>
                <ul class="en">{{#each highlights}}<li>{{{text_bold}}}</li>{{/each}}</ul>
                <ul class="ja">{{#each highlights}}<li>{{{text_ja_bold}}}</li>{{/each}}</ul>
                {{/each}}
                {{#if highlights}}
                <ul class="en">{{#each highlights}}<li>{{{text_bold}}}</li>{{/each}}</ul>
                <ul class="ja">{{#each highlights}}<li>{{{text_ja_bold}}}</li>{{/each}}</ul>
                {{/if}}
                {{/each}}
            </section>
            {{/ifIn}}
        </div>

        <div class="right-column">
            {{#ifIn meta.sections_right "education"}}
            <section class="section">
                <h2><span class="en">{{i18n.en.education}}</span><span class="ja">{{i18n.ja.education}}</span></h2>
                {{#each education}}
                <div class="education-item">
                    <div class="degree">
                        <span class="en">{{studyType}} in {{area}}</span>
                        <span class="ja">{{studyType_ja}}・{{area_ja}}</span>
                    </div>
                    <div class="institution">
                        <span class="en">{{institution}}</span><span class="ja">{{institution_ja}}</span>,
                        <span class="date">{{startDate}}–{{endDate}}</span>
                    </div>
                    <p style="margin-top:4px;font-size:9.5pt;">
                        <span class="en">{{description}}</span><span class="ja">{{description_ja}}</span>
                    </p>
                </div>
                {{/each}}
            </section>
            {{/ifIn}}
            {{#ifIn meta.sections_right "certificates"}}
            <section class="section">
                <h2><span class="en">{{i18n.en.certifications}}</span><span class="ja">{{i18n.ja.certifications}}</span></h2>
                {{#each certificates}}
                <div class="cert-item">
                    {{#if (eq level "primary")}}<strong>
                        <span class="en">{{name}}</span>{{#if name_ja}}<span class="ja">{{name_ja}}</span>{{else}}<span class="ja">{{name}}</span>{{/if}}
                    </strong>{{else}}
                        <span class="en">{{name}}</span>{{#if name_ja}}<span class="ja">{{name_ja}}</span>{{else}}<span class="ja">{{name}}</span>{{/if}}
                    {{/if}}
                </div>
                {{/each}}
            </section>
            {{/ifIn}}
            {{#ifIn meta.sections_right "awards"}}
            <section class="section">
                <h2><span class="en">{{i18n.en.awards}}</span><span class="ja">{{i18n.ja.awards}}</span></h2>
                {{#each awards}}
                <div class="award-item">
                    <strong>{{title}}{{#if date}} ({{date}}){{/if}}</strong><br>
                    <span class="en">{{summary}}</span><span class="ja">{{summary_ja}}</span>
                </div>
                {{/each}}
            </section>
            {{/ifIn}}
            {{#ifIn meta.sections_right "leadership"}}
            <section class="section">
                <h2><span class="en">{{i18n.en.leadership}}</span><span class="ja">{{i18n.ja.leadership}}</span></h2>
                {{#each leadership}}
                <div class="award-item">
                    <strong><span class="en">{{title}}</span><span class="ja">{{title_ja}}</span></strong><br>
                    <span class="en">{{summary}}</span><span class="ja">{{summary_ja}}</span>
                </div>
                {{/each}}
            </section>
            {{/ifIn}}
        </div>
    </div>
</div>

<script>
function setLang(l) {
    document.body.dataset.lang = l;
    document.getElementById('btn-en').classList.toggle('active', l==='en');
    document.getElementById('btn-ja').classList.toggle('active', l==='ja');
    document.documentElement.lang = l;
    localStorage.setItem('resume-lang', l);
}
(function(){ const s = localStorage.getItem('resume-lang'); if (s) setLang(s); })();
</script>
</body>
</html>
